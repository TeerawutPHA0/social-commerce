# ===== Database (Neon Postgres) =====
# ใช้ "Pooled connection" string จาก Neon (สำคัญสำหรับ serverless — กัน connection เต็ม)
# รูปแบบ: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ===== Admin auth =====
ADMIN_PASSWORD="เปลี่ยนรหัสผ่านนี้"
# สุ่มยาวๆ เช่น `openssl rand -hex 32`
SESSION_SECRET="เปลี่ยนเป็น-random-string-ยาวๆ"

# ===== ขนส่ง: เช็คสถานะพัสดุอัตโนมัติ (เว้นว่าง = ปิดปุ่มเช็ค) =====
THAILANDPOST_API_KEY=""
FLASH_MCH_ID=""
FLASH_SECRET_KEY=""
JT_API_ACCOUNT=""
JT_PRIVATE_KEY=""
JT_CUSTOMER_CODE=""
KERRY_API_TOKEN=""
KERRY_API_BASE=""
