# ===== Database (Neon Postgres) =====
# ใช้ "Pooled connection" string จาก Neon (สำคัญสำหรับ serverless — กัน connection เต็ม)
# รูปแบบ: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ===== Admin auth =====
# ⚠️ ห้ามใส่ค่าจริงในไฟล์นี้ (ไฟล์นี้ถูก commit) — ตั้งค่าจริงใน .env เท่านั้น
# ADMIN_EMAIL/ADMIN_PASSWORD ใช้ตอน bootstrap owner user
ADMIN_EMAIL="owner@example.com"
ADMIN_PASSWORD="change-me"
# สุ่มยาวๆ เช่น `openssl rand -hex 32` (ต้องไม่ซ้ำกันต่อ deployment)
SESSION_SECRET="generate-with-openssl-rand-hex-32"

# ===== ตั้งร้านใหม่ (npm run bootstrap) — ดู DEPLOY.md =====
# ชื่อร้านที่จะแสดงทั่วระบบ (จำเป็นสำหรับ bootstrap)
STORE_NAME="ชื่อร้านของลูกค้า"
# slug ภายใน — เว้นว่างได้ (ดีฟอลต์: แปลงจาก STORE_NAME, ถ้าเป็นไทยล้วนจะใช้ "store")
STORE_SLUG=""
# path/URL โลโก้ — เว้นว่าง = "/logo.jpg" (เปลี่ยนได้ภายหลังที่ /admin/settings)
STORE_LOGO=""
# (legacy) ใช้กับ prisma/create-owner.ts เท่านั้น — bootstrap ไม่ใช้ตัวนี้
DEFAULT_STORE_SLUG="puffiepiece"

# ===== ลิงก์ในข้อความแจ้งเตือน (LINE) =====
# ปกติระบบอ่านโดเมนจาก request เอง — ตั้งค่านี้เป็น fallback เท่านั้น (เช่นเรียกจาก cron/script)
# APP_URL="https://your-shop.vercel.app"

# ===== ที่เก็บรูปสลิป (Vercel Blob) =====
# สร้าง Blob store ใน Vercel dashboard (Storage → Create → Blob) แล้ว copy token มาวาง
# โลคัล: ใส่ใน .env / Vercel: ตัวแปรนี้ถูกเพิ่มให้อัตโนมัติเมื่อ connect Blob store เข้า project
BLOB_READ_WRITE_TOKEN=""

# ===== ขนส่ง: เช็คสถานะพัสดุอัตโนมัติ (เว้นว่าง = ปิดปุ่มเช็ค) =====
THAILANDPOST_API_KEY=""
FLASH_MCH_ID=""
FLASH_SECRET_KEY=""
JT_API_ACCOUNT=""
JT_PRIVATE_KEY=""
JT_CUSTOMER_CODE=""
KERRY_API_TOKEN=""
KERRY_API_BASE=""
