// Prisma schema — Social Commerce OMS (multi-tenant)
// ดู docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// ร้านค้า 1 ร้าน = 1 tenant — ออเดอร์/สินค้า/ผู้ใช้ทั้งหมดผูกกับร้านนี้
model Store {
  id   String @id @default(cuid())
  /// ใช้ทำ URL/subdomain ภายหลัง เช่น puffiepiece
  slug String @unique
  name String
  logo String @default("/logo.svg")

  /// ข้อมูลรับเงิน (แก้ผ่าน UI ที่ /admin/settings)
  payAccountName     String  @default("")
  /// [{ label, value, note? }] — บัญชี/พร้อมเพย์/วอลเล็ต
  payMethods         Json    @default("[]")
  /// path/URL รูป QR (null = ไม่มี) — ใช้เป็น fallback ถ้าไม่ได้ตั้ง promptpayId
  payQrImage         String?
  /// เลขพร้อมเพย์ (เบอร์มือถือ/บัตรปชช.) — ระบบ gen QR ตามยอดบิลอัตโนมัติ ("" = ไม่ใช้)
  promptpayId        String  @default("")
  payWarning         String?
  defaultShippingFee Float   @default(0)

  /// API key ของขนส่งต่อร้าน (ยังไม่เข้ารหัส — Phase 3 ค่อยทำ) | null = ใช้ค่า env กลาง
  courierConfig Json?

  /// แจ้งเตือนร้านผ่าน LINE OA (Phase 6) — token/secret เข้ารหัสก่อนเก็บ (ดู lib/crypto.ts)
  lineChannelToken  String? /// Channel Access Token (long-lived) สำหรับ push/reply
  lineChannelSecret String? /// Channel Secret สำหรับ verify ลายเซ็น webhook
  /// userId ของร้าน (ปลายทางรับ push) ที่จับได้จาก webhook ตอนร้านทักแชต OA
  lineUserId        String?
  lineNotifyEnabled Boolean @default(false)

  users    User[]
  orders   Order[]
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// ผู้ใช้แอดมินของร้าน (Phase 2 จะรื้อ auth มาใช้ตารางนี้แทนรหัสเดียวใน .env)
model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  /// owner | staff
  role         String @default("owner")

  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId String

  createdAt DateTime @default(now())

  @@index([storeId])
}

/// ออเดอร์ 1 รายการ (ตรงกับ type Order ใน src/types/order.ts)
model Order {
  id      String @id @default(cuid())
  /// token ลับใน URL เช่น order_9b1a2c3f (ยังคง unique ทั้งระบบ — เป็น secret link)
  token   String @unique
  /// เลขที่ใบสั่งซื้อที่ลูกค้าเห็น เช่น IQ21 — unique "ต่อร้าน" (ดู @@unique ด้านล่าง)
  orderNo String

  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId String

  /// snapshot ชื่อ/โลโก้ร้าน ณ ตอนสร้างบิล (กันแบรนด์เปลี่ยนแล้วบิลเก่าเพี้ยน)
  storeName String
  storeLogo String @default("/logo.svg")

  /// received | preparing | shipped | delivered
  status      String @default("received")
  shippingFee Float  @default(0)
  /// ส่วนลดต่อบิล (บาท) — หักจากยอดรวม
  discount    Float  @default(0)

  shippingName     String
  shippingPhone    String
  shippingAddress  String
  shippingPostcode String?
  shippingEmail    String?

  /// full | deposit — จ่ายเต็ม หรือ มัดจำ
  paymentType   String @default("full")
  /// ยอดมัดจำ (บาท) ใช้เมื่อ paymentType = deposit
  depositAmount Float  @default(0)

  /// unpaid | pending | paid (สำหรับมัดจำ paid = ได้รับมัดจำแล้ว)
  paymentStatus            String    @default("unpaid")
  paymentTransferredAmount Float     @default(0)
  paymentTransferredAt     DateTime?
  /// URL รูปสลิปบน Vercel Blob (null = ยังไม่อัพ)
  paymentSlipUrl           String?

  /// thailand-post | kerry | flash | jt (null = ยังไม่มีเลขพัสดุ)
  trackingCourier String?
  trackingNo      String?
  /// เวลาที่ร้านยืนยันว่า "จัดส่งสำเร็จ" (null = ยังไม่สำเร็จ)
  deliveredAt     DateTime?

  note String?

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, orderNo])
  @@index([storeId, status])
  /// เรียง/แบ่งหน้า "ออเดอร์ล่าสุดของร้าน" + กรองช่วงเดือน (สถิติ) ให้ใช้ index
  @@index([storeId, createdAt])
}

/// แคตตาล็อกสินค้าที่ร้านบันทึกไว้ (ไว้เลือกตอนสร้างบิล) — แยกจาก OrderItem
model Product {
  id   String @id @default(cuid())
  name String
  /// URL รูปสินค้า (Vercel Blob / local) — null = ไม่มีรูป
  image String?

  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId String

  price     Float    @default(0)
  createdAt DateTime @default(now())

  @@index([storeId, name])
}

/// รายการสินค้าในออเดอร์
model OrderItem {
  id      String @id @default(cuid())
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  name  String
  qty   Int
  price Float

  @@index([orderId])
}
